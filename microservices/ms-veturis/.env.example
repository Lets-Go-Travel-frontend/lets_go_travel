# Archivo de Ejemplo de Variables de Entorno (.env)
# IMPORTANTE: Copia este archivo a .env y rellena las variables de Veturis y Redis.
# NINGUN .env con credenciales reales debe subirse al repositorio.

# Entorno de Ejecución
NODE_ENV=production

# Puertos
PORT=3005
PORT_GRPC=50052

# Credenciales y Configuración de Veturis (URL de Producción)
VETURIS_URL=https://xmlservices.veturis.com/xmlWebServices.php
VETURIS_TIME_LIMIT=25
VETURIS_USER=TU_USUARIO_XML
VETURIS_PASSWORD=TU_PASSWORD_XML
VETURIS_AGENCY_USER=TU_AGENCY_USER
VETURIS_AGENCY_PASSWORD=TU_AGENCY_PASSWORD

# API Key del REST Bridge (Cualquier string seguro)
BRIDGE_API_KEY=tu_secreto_para_el_bridge

# Conexión a Redis (Datos estáticos de hoteles)
REDIS_URL=redis://127.0.0.1:6379