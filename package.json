{
  "name": "ms-veturis",
  "version": "1.0.0",
  "description": "ms-veturis: Microservicio especializado en integración Veturis API V3.9 con cumplimiento estricto B2B.",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "gen-proto": "proto-loader-gen-types --longs=String --enums=String --defaults --oneofs --grpcLib=@grpc/grpc-js --outDir=src/interfaces/gen/ proto/provider.proto"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.9.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "fast-xml-parser": "^4.5.4",
    "redis": "^5.11.0",
    "serverless-http": "^4.0.0",
    "xmlbuilder2": "^3.1.1"
  },
  "devDependencies": {
    "@grpc/proto-loader": "^0.7.15",
    "@types/redis": "^4.0.10",
    "@playwright/test": "^1.58.2",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0"
  }
}
